# Example environment file. Copy to .env and fill in real values for local testing.
# Do NOT commit your real .env.

# Admin address for deployments
ADMIN_ADDRESS=GADMIN_PLACEHOLDER

# Token contract address for reward pools
REWARD_TOKEN_ADDRESS=CTOKEN_PLACEHOLDER

# Soroban RPC URL (testnet)
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Network passphrase (testnet)
SOROBAN_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"

# Source identity for deploys
SOROBAN_IDENTITY=deployer
